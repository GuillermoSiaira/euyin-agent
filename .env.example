# Copiá este archivo a .env y ajustá los valores.
# NUNCA commitees .env con credenciales reales.

# URL base del Abu Engine. Local (Docker/uvicorn) por defecto.
# Para apuntar a producción: cambiar SOLO esta variable, sin tocar código.
#
# NOTA: la imagen Docker local puede estar desactualizada (sin /api/mundana/*).
# El Cloud Run de producción SÍ tiene el módulo mundana y sus rutas son públicas:
#   ABU_ENGINE_URL=https://abu-engine-bbrsyawaca-uc.a.run.app
# Apuntando ahí, calcular_transitos activa el enrichment mundana automáticamente.
ABU_ENGINE_URL=http://localhost:8000

# Service key (machine-to-machine) — desbloquea linea_biografica y demás
# endpoints protegidos del engine. La misma key debe estar configurada en el
# engine (env var ABU_SERVICE_KEY, desde Secret Manager en Cloud Run).
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
# ABU_SERVICE_KEY=

# Token Bearer (JWT Firebase) — opcional, solo para probar como usuario humano.
# Expira ~1h; para el agente usar ABU_SERVICE_KEY.
# ABU_AUTH_TOKEN=

# Raíz del repo ai-oracle, fuente del corpus doctrinal para traer_doctrina().
ABU_DOCTRINE_ROOT=D:/projects/ai-oracle

# Timeout HTTP en segundos para llamadas al engine.
ABU_HTTP_TIMEOUT=45
