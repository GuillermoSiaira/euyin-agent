# Copy this file to .env and adjust values.
# NEVER commit .env with real credentials.

# Abu Engine base URL. Default: local Docker/uvicorn.
# For production (Cloud Run, public, mundana module included):
#   ABU_ENGINE_URL=https://abu-engine-bbrsyawaca-uc.a.run.app
ABU_ENGINE_URL=http://localhost:8000

# Service key (machine-to-machine) — unlocks protected endpoints
# (biography, relocation, chart/extended). Must match the engine's
# ABU_SERVICE_KEY env var (from Secret Manager on Cloud Run).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ABU_SERVICE_KEY=

# Bearer token (Firebase JWT) — optional, for testing as a human user.
# Expires ~1h; for the agent use ABU_SERVICE_KEY instead.
# ABU_AUTH_TOKEN=

# Root of the ai-oracle repo (source of doctrinal corpus for traer_doctrina).
# Point to wherever you cloned https://github.com/<org>/ai-oracle.
ABU_DOCTRINE_ROOT=./ai-oracle

# HTTP timeout in seconds for engine calls.
ABU_HTTP_TIMEOUT=45
